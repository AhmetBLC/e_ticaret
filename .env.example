PORT=3000
NODE_ENV=development

# Interactive API docs (when server is running):
#   Swagger UI  → http://localhost:3000/api-docs
#   OpenAPI JSON → http://localhost:3000/api-docs.json

# PostgreSQL — use either DATABASE_URL or the PG_* variables below
DATABASE_URL=postgres://user:password@localhost:5432/e_ticaret
# Set to true if your host requires SSL (many cloud providers)
DATABASE_SSL=false

# Alternative to DATABASE_URL (uncomment and fill if not using URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=user
# PGPASSWORD=password
# PGDATABASE=e_ticaret

# JWT (required for auth routes once implemented)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Password hashing cost (10–15 typical)
BCRYPT_ROUNDS=12

# Flutter / web dev: e.g. http://localhost:* or specific origin. Use * for allow-all.
CORS_ORIGIN=*

# Logging (API server)
# LOG_LEVEL=debug|info|warn|error|silent  (default: debug in dev, info in production)
# LOG_REQUESTS=false  — disable one-line HTTP request logs
# LOG_REQUEST_BODY=true  — log sanitized JSON bodies at debug (never log raw passwords)
# LOG_LEVEL=debug
# LOG_REQUESTS=true
# LOG_REQUEST_BODY=false
